{% comment %}
  Loyalty Widget Block
  Add this as a Theme App Extension block.
  Shopify injects customer context when logged in.
{% endcomment %}

<div id="loyalty-widget-root"></div>

<script>
  // Inject app context for the widget JS
  window.__LOYALTY_APP_URL__ = {{ shop.metafields.loyalty.app_url | json }};
  window.__LOYALTY_SHOP__ = {{ shop.permanent_domain | json }};

  {% if customer %}
    window.__LOYALTY_CUSTOMER_ID__ = {{ customer.id | json }};
    window.__LOYALTY_CUSTOMER_EMAIL__ = {{ customer.email | json }};
    window.__LOYALTY_CUSTOMER_FIRST_NAME__ = {{ customer.first_name | json }};
    window.__LOYALTY_CUSTOMER_LAST_NAME__ = {{ customer.last_name | json }};
  {% else %}
    window.__LOYALTY_CUSTOMER_ID__ = null;
  {% endif %}
</script>

{{ 'loyalty-widget.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Loyalty Widget",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Your Rewards"
    }
  ]
}
{% endschema %}
