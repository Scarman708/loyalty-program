// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model LoyaltyCustomer {
  id                String   @id @default(cuid())
  shop              String
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  points            Int      @default(0)
  lifetimePoints    Int      @default(0)
  tier              String   @default("bronze")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions      PointTransaction[]
  vouchers          RedemptionVoucher[]
  referrerRelations ReferralRelationship[] @relation("ReferrerRelations")
  refereeRelation   ReferralRelationship?  @relation("RefereeRelations")

  @@unique([shop, shopifyCustomerId])
  @@index([shop])
}

model ReferralRelationship {
  id          String   @id @default(cuid())
  shop        String
  referrerId  String                        // LoyaltyCustomer.id who shared the code
  refereeId   String   @unique              // LoyaltyCustomer.id who used the code
  referralCode String                       // the code that was used
  status      String   @default("pending")  // pending | signup_bonus_paid | completed | voided
  // Points tracking
  signupBonusPaid    Boolean  @default(false)
  orderBonusPaid     Boolean  @default(false)
  referrerBonusPts   Int?                   // pts awarded to referrer after order
  refereeBonusPts    Int?                   // pts awarded to referee after order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  referrer    LoyaltyCustomer @relation("ReferrerRelations", fields: [referrerId], references: [id])
  referee     LoyaltyCustomer @relation("RefereeRelations",  fields: [refereeId],  references: [id])

  @@index([shop, referrerId])
  @@index([referralCode])
}

model PointTransaction {
  id          String   @id @default(cuid())
  shop        String
  customerId  String
  type        String
  points      Int
  status      String   @default("active")
  orderId     String?
  orderName   String?
  note        String?
  createdAt   DateTime @default(now())

  customer    LoyaltyCustomer @relation(fields: [customerId], references: [id])

  @@index([shop, customerId])
}

model RedemptionVoucher {
  id             String   @id @default(cuid())
  shop           String
  customerId     String
  code           String
  discountAmount Float
  pointsUsed     Int
  status         String   @default("active")
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  customer       LoyaltyCustomer @relation(fields: [customerId], references: [id])

  @@index([shop, customerId])
  @@index([code])
}

model TierConfig {
  id        String   @id @default(cuid())
  shop      String   @unique
  bronze    Int      @default(0)
  silver    Int      @default(500)
  gold      Int      @default(2000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltySettings {
  id                   String   @id @default(cuid())
  shop                 String   @unique

  pointsPerCurrency    Float    @default(10)
  orderAmountType      String   @default("subtotal")
  bronzeMultiplier     Float    @default(1.0)
  silverMultiplier     Float    @default(1.25)
  goldMultiplier       Float    @default(1.5)

  bronzeRedemptionRate Float    @default(100)
  silverRedemptionRate Float    @default(80)
  goldRedemptionRate   Float    @default(60)

  voucherPreset1       Int      @default(500)
  voucherPreset2       Int      @default(1000)
  voucherPreset3       Int      @default(2000)

  // Referral settings
  referralSignupBonus  Int      @default(100)  // pts to referee on signup
  referralReferrerPct  Float    @default(10)   // % of referee's first order pts to referrer
  referralRefereePct   Float    @default(10)   // % of referee's first order pts to referee (bonus)

  accentColor          String   @default("#d4a017")
  bgColor              String   @default("#0d0d0d")
  textColor            String   @default("#ffffff")
  buttonColor          String   @default("#d4a017")
  buttonTextColor      String   @default("#0d0d0d")
  borderRadius         Int      @default(16)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
